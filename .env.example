# Copy this file to .env and replace each placeholder.
IQAIR_API_KEY=replace_with_your_key

# Use the pooled Neon connection string for the deployed API.
DATABASE_URL=postgresql://user:password@your-endpoint-pooler.neon.tech/neondb?sslmode=require

# DataHub's PostgreSQL connector requires the host separately.
DATAHUB_POSTGRES_HOST=your-endpoint.neon.tech

# This is the browser origin allowed to call the Python API.
FRONTEND_URL=http://localhost:3000
